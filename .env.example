# Copy to .env.local. NEVER commit real secrets.
# "staging" => noindex + staging banner + forms go to TEST inbox only.
NEXT_PUBLIC_SITE_ENV=staging
NEXT_PUBLIC_SITE_URL=https://staging.rodgersfertilizer.example
# STAGING = TEST ONLY. Do not set live staff recipients until owner approval.
LEAD_TEST_INBOX=staging-test@example.com
EMAIL_API_KEY=
# Analytics placeholders — do not invent real IDs.
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# --- Optional: password-protect the staging preview (Basic Auth) ------------
# Set BOTH to require a login before the client can view the staging URL.
# Leave blank for an open link. (Local `npm run dev` stays open if unset.)
STAGING_USER=
STAGING_PASS=
